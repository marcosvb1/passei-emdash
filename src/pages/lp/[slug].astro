// Pick an available sprite symbol for (icon name, filled?).
function iconId(name: string, fill: boolean): string | null {
	if (fill && ICONS[`${name}-fill`]) return `${name}-fill`;
	if (ICONS[name]) return name;
	if (ICONS[`${name}-fill`]) return `${name}-fill`;
	return null;
}

const ICON_SPAN =
	/<span\b([^>]*?)\bclass="([^"]*\bmaterial-symbols[^"]*)"([^>]*)>\s*([a-z0-9_]+)\s*<\/span>/gi;

// Replace icon-font <span>s with inline SVG <use>, inject a once-only symbol
// sprite, and drop the 312KB render-blocking Google Fonts stylesheet. Falls
// back to the original markup for any icon we don't carry.
function inlineIcons(html: string): string {
	const used = new Set<string>();
	let out = html.replace(ICON_SPAN, (m, pre, cls, post, name) => {
		const attrs = `${pre} ${post}`;
		const isFill = /FILL'?\s*1/i.test(attrs);
		const id = iconId(name, isFill);
		if (!id) return m;
		used.add(id);
		const styleMatch = attrs.match(/\bstyle="([^"]*)"/i);
		let style = styleMatch ? styleMatch[1] : "";
		style = style.replace(/font-variation-settings\s*:[^;]*;?/gi, "");
		if (!/font-size/i.test(style)) style = `font-size:24px;${style}`;
		style = `width:1em;height:1em;vertical-align:middle;${style}`;
		return `<svg class="${cls}" style="${style}" viewBox="0 -960 960 960" fill="currentColor" aria-hidden="true"><use href="#ms-${id}"/></svg>`;
	});

	if (used.size === 0) return out;

	out = out.replace(/<link\b[^>]*Material\+Symbols[^>]*>\s*/gi, "");

	const sprite =
		`<svg xmlns="http://www.w3.org/2000/svg" style="position:absolute;width:0;height:0;overflow:hidden" aria-hidden="true">` +
		[...used]
			.map((id) => `<symbol id="ms-${id}" viewBox="0 -960 960 960">${ICONS[id]}</symbol>`)
			.join("") +
		`</svg>`;
	out = /<body\b[^>]*>/i.test(out)
		? out.replace(/(<body\b[^>]*>)/i, `$1${sprite}`)
		: sprite + out;

	return out;
}

const page = new Response(inlineIcons(entry.data.html), {
	headers: {
		"content-type": "text/html; charset=utf-8",
	},
});

// Route EmDash media <img> through the Worker's on-the-fly optimizer by
// appending ?w=<intrinsic width> (capped). See src/worker.ts.
const MEDIA_PREFIX = "/_emdash/api/media/file/";
return new HTMLRewriter()
	.on("img", {
		element(el) {
			const src = el.getAttribute("src");
			if (!src || !src.includes(MEDIA_PREFIX) || src.includes("?")) return;
			const w = Number(el.getAttribute("width"));
			const width = Number.isFinite(w) && w > 0 ? Math.min(w, 1536) : 1000;
			el.setAttribute("src", `${src}?w=${width}`);
		},
	})
	.transform(page);

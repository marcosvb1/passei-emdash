// Full-bleed landing pages: serve the raw HTML stored in the `lp` collection
// verbatim (no Base layout). Before serving we (1) inline Material Symbols
// icon-font glyphs as SVG and drop the render-blocking Google Fonts <link>,
// then (2) route media <img> through the Worker image optimizer (?w=). The
// stored HTML in the entry is never modified — all of this is per-request.
import { getEmDashEntry, decodeSlug } from "emdash";

const slug = decodeSlug(Astro.params.slug);

if (!slug) {
	return new Response("Not found", { status: 404 });
}

const { entry } = await getEmDashEntry("lp", slug);

if (!entry || !entry.data?.html) {
	return new Response("Not found", { status: 404 });
}

